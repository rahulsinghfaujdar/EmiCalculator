{
  "name": "emiccalculator",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android:dev:run": "npx react-native run-android --mode devDebug",
    "android:prod:run": "npx react-native run-android --mode prodDebug",
    "android:log": "npx react-native log-android",
    "devTools": "react-devtools",
    "android2": "bash -c 'npm run start --reset-cache & npx wait-on tcp:8081 && sleep 5 && adb shell input keyevent 82 && npm run devTools & npm run android:dev:run & npm run android:log'",
    "android": "bash -c 'npm run start --reset-cache & npx wait-on tcp:8081 xdg-open http://localhost:8081 && npm run android:dev:run & sleep 5 && adb shell input keyevent 82 && npm run devTools & npm run android:log'",
    "android:debug": "cd android && ./gradlew assembleDebug",
    "android:build": "cd android && ./gradlew assemble${BUILD_VARIANT} -PbuildEnv=${BUILD_ENV}",
    "android:dev:debug": "cd android && ./gradlew assembleDevDebug",
    "android:prod:debug": "cd android && ./gradlew assembleProdDebug",
    "android:dev:release": "cd android && ./gradlew assembleDevRelease",
    "android:prod:release": "cd android && ./gradlew assembleProdRelease",
    "ios": "react-native run-ios",
    "lint": "eslint .",
    "start": "react-native start",
    "test": "jest"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-firebase/app": "^24.0.0",
    "@react-native-firebase/crashlytics": "^24.0.0",
    "@react-native-firebase/remote-config": "^24.0.0",
    "@react-native/new-app-screen": "0.85.0",
    "@reduxjs/toolkit": "^2.11.2",
    "react": "19.2.3",
    "react-native": "0.85.0",
    "react-native-safe-area-context": "^5.7.0",
    "react-native-webview": "^13.16.1",
    "react-redux": "^9.2.0",
    "redux": "^5.0.1",
    "redux-persist": "^6.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@babel/runtime": "^7.29.2",
    "@react-native-community/cli": "20.1.3",
    "@react-native-community/cli-platform-android": "20.1.3",
    "@react-native-community/cli-platform-ios": "20.1.3",
    "@react-native/babel-preset": "0.85.0",
    "@react-native/eslint-config": "0.85.0",
    "@react-native/jest-preset": "0.85.0",
    "@react-native/metro-config": "0.85.0",
    "@react-native/typescript-config": "0.85.0",
    "@types/jest": "^30.0.0",
    "@types/react": "^19.2.14",
    "@types/react-test-renderer": "^19.1.0",
    "eslint": "^9.39.4",
    "jest": "^30.3.0",
    "prettier": "3.8.2",
    "react-test-renderer": "19.2.3",
    "typescript": "^6.0.2"
  },
  "engines": {
    "node": ">= 20.20.2"
  },
  "overrides": {
    "glob": "^13.0.6"
  }
}
